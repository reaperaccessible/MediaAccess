IDD_SCHED_ADD DIALOGEX 0, 0, 300, 190
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add Scheduled Event"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "&Name:", -1, 7, 12, 30, 10
    EDITTEXT        IDC_SCHED_NAME, 45, 10, 248, 14, ES_AUTOHSCROLL
    LTEXT           "&Action:", -1, 7, 32, 30, 10
    COMBOBOX        IDC_SCHED_ACTION, 45, 30, 100, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Source:", -1, 7, 52, 30, 10
    COMBOBOX        IDC_SCHED_SOURCE, 45, 50, 80, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&File:", -1, 7, 72, 20, 10
    EDITTEXT        IDC_SCHED_FILE, 30, 70, 220, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_SCHED_BROWSE, 253, 70, 20, 14
    LTEXT           "Ra&dio:", -1, 7, 72, 25, 10
    COMBOBOX        IDC_SCHED_RADIO, 35, 70, 238, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Date:", -1, 7, 92, 25, 10
    CONTROL         "", IDC_SCHED_DATE, "SysDateTimePick32", DTS_SHORTDATECENTURYFORMAT | WS_TABSTOP, 35, 90, 100, 14
    LTEXT           "&Time:", -1, 145, 92, 25, 10
    CONTROL         "", IDC_SCHED_TIME, "SysDateTimePick32", DTS_TIMEFORMAT | WS_TABSTOP, 172, 90, 80, 14
    LTEXT           "&Repeat:", -1, 7, 112, 30, 10
    COMBOBOX        IDC_SCHED_REPEAT, 45, 110, 100, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "D&uration:", -1, 7, 132, 35, 10
    EDITTEXT        IDC_SCHED_DURATION, 45, 130, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "minutes (0 = no limit)", -1, 90, 132, 80, 10
    LTEXT           "S&top:", -1, 175, 132, 25, 10
    COMBOBOX        IDC_SCHED_STOP, 200, 130, 93, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "&Enabled", IDC_SCHED_ENABLED, 7, 152, 60, 10
    DEFPUSHBUTTON   "OK", IDOK, 189, 170, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 243, 170, 50, 14
END

