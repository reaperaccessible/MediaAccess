#include <windows.h>
#include "resource.h"

// Application icon
IDI_APPICON ICON "MediaAccess.ico"

IDM_MAIN_MENU MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open...\tCtrl+O", IDM_FILE_OPEN
        MENUITEM "Add &Folder...\tCtrl+Shift+O", IDM_FILE_ADD_FOLDER
        MENUITEM "&Playlist...\tCtrl+P", IDM_FILE_PLAYLIST
        MENUITEM "Open &URL...\tCtrl+U", IDM_FILE_OPEN_URL
        MENUITEM "Paste from clip&board\tCtrl+V", IDM_FILE_PASTE
        MENUITEM "&YouTube...\tCtrl+Y", IDM_FILE_YOUTUBE
        MENUITEM "&Radio...\tCtrl+R", IDM_FILE_RADIO
        MENUITEM "&Add Stream to Favorites...\tCtrl+D", IDM_FILE_ADD_TO_FAVORITES
        MENUITEM "&Podcasts...\tCtrl+Shift+P", IDM_FILE_PODCAST
        MENUITEM "&Schedule...\tCtrl+S", IDM_FILE_SCHEDULE
        MENUITEM "Song &History...\tCtrl+Shift+H", IDM_VIEW_SONG_HISTORY
        MENUITEM SEPARATOR
        MENUITEM "Open &book...",                  IDM_FILE_OPEN_BOOK
        MENUITEM SEPARATOR
        POPUP "Recent &Files"
        BEGIN
            MENUITEM "(Empty)", 0, GRAYED
        END
        MENUITEM SEPARATOR
        MENUITEM "&Hide to Tray\tCtrl+H", IDM_FILE_HIDE_TRAY
        MENUITEM SEPARATOR
        MENUITEM "O&ptions...\tCtrl+,", IDM_TOOLS_OPTIONS
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tAlt+F4", IDM_FILE_EXIT
    END
    POPUP "&Playback"
    BEGIN
        MENUITEM "&Play\tX", IDM_PLAY_PLAY
        MENUITEM "Pa&use\tC", IDM_PLAY_PAUSE
        MENUITEM "Play/Pause\tSpace", IDM_PLAY_PLAYPAUSE
        MENUITEM "&Stop\tV", IDM_PLAY_STOP
        MENUITEM SEPARATOR
        MENUITEM "P&revious\tZ", IDM_PLAY_PREV
        MENUITEM "&Next\tB", IDM_PLAY_NEXT
        MENUITEM SEPARATOR
        MENUITEM "S&huffle\tH", IDM_PLAY_SHUFFLE
        MENUITEM "R&epeat\tE", IDM_PLAY_REPEAT_TOGGLE
        MENUITEM SEPARATOR
        MENUITEM "Seek &Backward\tLeft", IDM_PLAY_SEEKBACK
        MENUITEM "Seek &Forward\tRight", IDM_PLAY_SEEKFWD
        MENUITEM "&Beginning\tHome", IDM_PLAY_BEGINNING
        MENUITEM "&Jump to Time...\tJ", IDM_PLAY_JUMPTOTIME
        MENUITEM SEPARATOR
        MENUITEM "Volume &Up\tUp", IDM_PLAY_VOLUP
        MENUITEM "Volume &Down\tDown", IDM_PLAY_VOLDOWN
        MENUITEM SEPARATOR
        MENUITEM "Speak &Elapsed\tCtrl+Shift+E", IDM_PLAY_ELAPSED
        MENUITEM "Speak &Remaining\tCtrl+Shift+R", IDM_PLAY_REMAINING
        MENUITEM "Speak &Total\tCtrl+Shift+T", IDM_PLAY_TOTAL
    END
    POPUP "&Video"
    BEGIN
        MENUITEM "&Fullscreen\tF11",                IDM_VIDEO_FULLSCREEN
        MENUITEM SEPARATOR
        MENUITEM "Cycle &Subtitles",                IDM_VIDEO_SUB_CYCLE
        MENUITEM "&Load Subtitle File...",          IDM_VIDEO_SUB_LOAD
        MENUITEM "Subtitles &Off",                  IDM_VIDEO_SUB_OFF
        MENUITEM SEPARATOR
        MENUITEM "Cycle &Audio Track",              IDM_VIDEO_AUDIO_CYCLE
        MENUITEM SEPARATOR
        MENUITEM "Cycle Aspect &Ratio",             IDM_VIDEO_ASPECT
        MENUITEM SEPARATOR
        MENUITEM "Take Scr&eenshot",                IDM_VIDEO_SCREENSHOT
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Actions...\tF4",                 IDM_TOOLS_ACTIONS
        MENUITEM "&Book library...",                IDM_TOOLS_BOOK_LIBRARY
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Manual\tF1", IDM_HELP_MANUAL
        MENUITEM "&Readme", IDM_HELP_README
        MENUITEM "Check for &Updates...", IDM_HELP_UPDATES
        MENUITEM SEPARATOR
        MENUITEM "Set as &default media player...", IDM_HELP_SET_DEFAULT
        MENUITEM SEPARATOR
        MENUITEM "&Audio formats...", IDM_HELP_PLUGINS
        MENUITEM SEPARATOR
        MENUITEM "&Test YouTube playback", IDM_HELP_TEST_YOUTUBE
        MENUITEM "C&lear YouTube cache...", IDM_HELP_CLEAR_YT_CACHE
        MENUITEM SEPARATOR
        MENUITEM "Audit dialog &layout...", IDM_HELP_AUDIT_LAYOUT
    END
END

IDD_OPTIONS DIALOGEX 0, 0, 340, 260
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Options"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "", IDC_TAB, "SysTabControl32", WS_TABSTOP, 7, 7, 326, 225

    // Playback tab controls (shown when tab 0 selected)
    LTEXT           "&Output device:", IDC_LABEL_PLAYBACK_OUTPUT_DEVICE, 17, 30, 55, 10
    COMBOBOX        IDC_SOUNDCARD, 75, 28, 188, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "&Allow volume above 100%", IDC_ALLOW_AMPLIFY, 17, 48, 160, 10
    AUTOCHECKBOX    "&Remember playback state on exit", IDC_REMEMBER_STATE, 17, 61, 180, 10
    LTEXT           "Remember p&osition if longer than:", IDC_LABEL_PLAYBACK_REMEMBER_POS, 17, 76, 125, 10
    COMBOBOX        IDC_REMEMBER_POS, 145, 74, 118, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "&Bring window to front when opening files", IDC_BRING_TO_FRONT, 17, 92, 230, 10
    AUTOCHECKBOX    "&Load all files in folder when opening single file", IDC_LOAD_FOLDER, 17, 105, 260, 10
    AUTOCHECKBOX    "&Minimize to system tray", IDC_MINIMIZE_TO_TRAY, 17, 118, 155, 10
    AUTOCHECKBOX    "Show &track name in window title", IDC_SHOW_TITLE, 17, 131, 220, 10
    AUTOCHECKBOX    "Auto-ad&vance to next playlist item", IDC_AUTO_ADVANCE, 17, 144, 150, 10
    AUTOCHECKBOX    "&Follow playback in playlist dialog", IDC_PLAYLIST_FOLLOW, 17, 157, 180, 10
    AUTOCHECKBOX    "Check for &updates on startup", IDC_CHECK_UPDATES, 17, 170, 170, 10
    AUTOCHECKBOX    "Allow &multiple instances", IDC_MULTI_INSTANCE, 17, 183, 150, 10
    AUTOCHECKBOX    "Register all supported &file types", IDC_REGISTER_FILE_TYPES, 155, 183, 180, 10
    LTEXT           "Re&wind on pause (ms):", IDC_REWIND_LABEL, 170, 145, 95, 10
    EDITTEXT        IDC_REWIND_ON_PAUSE, 250, 143, 30, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Volu&me step:", IDC_LABEL_PLAYBACK_VOLUME_STEP, 160, 118, 65, 10
    COMBOBOX        IDC_VOLUME_STEP, 230, 116, 55, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Lan&guage:", IDC_LABEL_LANGUAGE, 17, 200, 40, 10
    COMBOBOX        IDC_LANGUAGE_COMBO, 60, 198, 90, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    // Recording tab controls (shown when tab 1 selected)
    LTEXT           "Record audio output to file. Press R to toggle recording.", IDC_LABEL_RECORDING_DESCRIPTION, 17, 30, 320, 10
    LTEXT           "&Output folder:", IDC_LABEL_RECORDING_OUTPUT_FOLDER, 17, 50, 65, 10
    EDITTEXT        IDC_REC_PATH, 85, 48, 140, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "&Browse...", IDC_REC_BROWSE, 228, 47, 50, 14
    LTEXT           "Filename &template:", IDC_LABEL_RECORDING_TEMPLATE, 17, 72, 85, 10
    EDITTEXT        IDC_REC_TEMPLATE, 105, 70, 120, 14, ES_AUTOHSCROLL
    LTEXT           "(Uses strftime format: %Y=year, %m=month, %d=day, %H=hour, %M=min, %S=sec)", IDC_LABEL_RECORDING_TEMPLATE_HELP, 17, 88, 290, 10
    LTEXT           "&Format:", IDC_LABEL_RECORDING_FORMAT, 17, 108, 35, 10
    COMBOBOX        IDC_REC_FORMAT, 50, 106, 70, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Bitrate:", IDC_LABEL_RECORDING_BITRATE, 130, 108, 30, 10
    COMBOBOX        IDC_REC_BITRATE, 163, 106, 70, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "(Bitrate only applies to MP3 and OGG formats)", IDC_LABEL_RECORDING_BITRATE_NOTE, 17, 125, 200, 10

    // Downloads tab controls (shown when tab 2 selected)
    LTEXT           "Configure podcast episode download settings.", IDC_LABEL_DOWNLOADS_DESCRIPTION, 17, 30, 290, 10
    LTEXT           "&Downloads folder:", IDC_LABEL_DOWNLOADS_FOLDER, 17, 50, 115, 10
    EDITTEXT        IDC_DOWNLOAD_PATH, 17, 62, 205, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "&Browse...", IDC_DOWNLOAD_BROWSE, 225, 61, 50, 14
    AUTOCHECKBOX    "&Organize downloads into folders by feed title", IDC_DOWNLOAD_ORGANIZE, 17, 82, 260, 10

    // Speech tab controls (shown when tab 3 selected)
    LTEXT           "Configure speech feedback for various events.", IDC_LABEL_SPEECH_DESCRIPTION, 17, 30, 230, 10
    AUTOCHECKBOX    "&Announce track changes", IDC_SPEECH_TRACKCHANGE, 17, 50, 150, 10
    AUTOCHECKBOX    "Speak &volume when adjusted", IDC_SPEECH_VOLUME, 17, 70, 170, 10
    AUTOCHECKBOX    "Speak &effect value when adjusted", IDC_SPEECH_EFFECT, 17, 90, 210, 10
    AUTOCHECKBOX    "Announce YouTube effects activation", IDC_SPEECH_YT_HYBRID, 17, 110, 260, 10

    // Movement tab controls (shown when tab 4 selected)
    LTEXT           "Seek amounts (use , and . to cycle):", IDC_LABEL_MOVEMENT_DESCRIPTION, 17, 30, 260, 10
    AUTOCHECKBOX    "&1 second", IDC_SEEK_1S, 17, 45, 60, 10
    AUTOCHECKBOX    "&5 seconds", IDC_SEEK_5S, 17, 60, 60, 10
    AUTOCHECKBOX    "1&0 seconds", IDC_SEEK_10S, 17, 75, 60, 10
    AUTOCHECKBOX    "&30 seconds", IDC_SEEK_30S, 17, 90, 60, 10
    AUTOCHECKBOX    "1 &minute", IDC_SEEK_1M, 17, 105, 60, 10
    AUTOCHECKBOX    "5 m&inutes", IDC_SEEK_5M, 17, 120, 60, 10
    AUTOCHECKBOX    "10 min&utes", IDC_SEEK_10M, 17, 135, 60, 10
    AUTOCHECKBOX    "3&0 minutes", IDC_SEEK_30M, 80, 120, 60, 10
    AUTOCHECKBOX    "1 &hour", IDC_SEEK_1H, 80, 135, 60, 10
    AUTOCHECKBOX    "1 &track", IDC_SEEK_1T, 17, 150, 60, 10
    AUTOCHECKBOX    "5 t&racks", IDC_SEEK_5T, 17, 165, 60, 10
    AUTOCHECKBOX    "10 trac&ks", IDC_SEEK_10T, 80, 165, 60, 10
    AUTOCHECKBOX    "1 c&hapter (if available)", IDC_CHAPTER_SEEK, 150, 165, 110, 10

    // (Global Hotkeys tab removed in v1.41 — global hotkeys are now managed
    // exclusively from Tools → Actions, Global category.)

    // Effects tab controls (shown when tab 5 selected)
    LTEXT           "Stream effects ([ ] to cycle, Up/Down to adjust):", IDC_LABEL_EFFECTS_DESCRIPTION, 17, 30, 280, 10
    AUTOCHECKBOX    "&Volume (0-400%)", IDC_EFFECT_VOLUME, 17, 45, 100, 10
    AUTOCHECKBOX    "&Pitch (-12 to +12 semitones)", IDC_EFFECT_PITCH, 17, 60, 140, 10
    AUTOCHECKBOX    "&Tempo (-50% to +100%)", IDC_EFFECT_TEMPO, 17, 75, 120, 10
    AUTOCHECKBOX    "Playback &Rate (0.5x - 2x)", IDC_EFFECT_RATE, 17, 90, 120, 10
    LTEXT           "Step:", IDC_LABEL_EFFECTS_STEP, 140, 91, 25, 10
    COMBOBOX        IDC_RATE_STEP_MODE, 162, 89, 70, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "DSP effects (enable to add their parameters to cycle list):", IDC_LABEL_EFFECTS_DSP_DESCRIPTION, 17, 110, 260, 10
    LTEXT           "Re&verb:", IDC_LABEL_EFFECTS_REVERB, 17, 127, 60, 10
    COMBOBOX        IDC_DSP_REVERB, 80, 125, 140, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "&Echo", IDC_DSP_ECHO, 17, 145, 60, 10
    AUTOCHECKBOX    "E&Q (Bass/Mid/Treble)", IDC_DSP_EQ, 17, 160, 110, 10
    AUTOCHECKBOX    "&Compressor", IDC_DSP_COMPRESSOR, 17, 175, 70, 10
    AUTOCHECKBOX    "&Stereo Width (0-200%)", IDC_DSP_STEREOWIDTH, 100, 145, 110, 10
    AUTOCHECKBOX    "Ce&nter Cancel (-100 to +100%)", IDC_DSP_CENTERCANCEL, 100, 160, 160, 10
    AUTOCHECKBOX    "&3D Audio (HRTF/Binaural)", IDC_DSP_SPATIAL, 100, 175, 120, 10
    AUTOCHECKBOX    "Co&nvolution Reverb", IDC_DSP_CONVOLUTION, 17, 190, 90, 10
    LTEXT           "IR File:", IDC_LABEL_EFFECTS_IR_FILE, 110, 191, 42, 10
    EDITTEXT        IDC_CONV_IR, 155, 189, 70, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "...", IDC_CONV_BROWSE, 228, 189, 18, 14

    // Advanced tab controls (shown when tab 7 selected)
    LTEXT           "Audio buffer settings (changes apply on next file load):", IDC_LABEL_ADVANCED_BUFFER_DESC, 17, 30, 290, 10
    LTEXT           "&Buffer size:", IDC_LABEL_ADVANCED_BUFFER_SIZE, 17, 50, 80, 10
    COMBOBOX        IDC_BUFFER_SIZE, 100, 48, 100, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Update period:", IDC_LABEL_ADVANCED_UPDATE_PERIOD, 125, 50, 95, 10
    COMBOBOX        IDC_UPDATE_PERIOD, 225, 48, 100, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Lower values reduce latency but may cause audio glitches.", IDC_LABEL_ADVANCED_LATENCY_NOTE, 17, 95, 300, 10
    LTEXT           "Tempo/pitch &algorithm (changes apply on next file load):", IDC_LABEL_ADVANCED_TEMPO_ALGO, 17, 118, 260, 10
    COMBOBOX        IDC_TEMPO_ALGORITHM, 17, 133, 200, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "EQ frequencies (Hz) - changes apply on next EQ enable:", IDC_LABEL_ADVANCED_EQ_FREQ, 17, 158, 290, 10
    LTEXT           "Bass (20-500):", IDC_LABEL_ADVANCED_EQ_BASS, 17, 175, 65, 10
    EDITTEXT        IDC_EQ_BASS_FREQ, 85, 173, 35, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Mid (200-5k):", IDC_LABEL_ADVANCED_EQ_MID, 125, 175, 70, 10
    EDITTEXT        IDC_EQ_MID_FREQ, 200, 173, 25, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Treble (2k-20k):", IDC_LABEL_ADVANCED_EQ_TREBLE, 225, 175, 65, 10
    EDITTEXT        IDC_EQ_TREBLE_FREQ, 280, 173, 45, 14, ES_AUTOHSCROLL | ES_NUMBER
    AUTOCHECKBOX    "&Legacy volume (faster, but affects recordings)", IDC_LEGACY_VOLUME, 17, 195, 260, 10
    AUTOCHECKBOX    "Disable &batch delay (only catches one file at a time)", IDC_DISABLE_BATCH, 17, 209, 220, 10
    PUSHBUTTON      "Reset station/podcast &order to alphabetical", IDC_RESET_LIST_ORDER, 17, 228, 260, 14

    // YouTube tab controls (shown when tab 8 selected)
    // yt-dlp is bundled and auto-updated; no path field needed.
    LTEXT           "YouTube Data &API key (optional, enables search):", IDC_LABEL_YOUTUBE_API_KEY, 17, 30, 260, 10
    EDITTEXT        IDC_YT_APIKEY, 17, 45, 256, 14, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT           "Get an API key from: console.cloud.google.com", IDC_LABEL_YOUTUBE_API_HELP, 17, 65, 200, 10
    LTEXT           "Without API key, yt-dlp will be used for search (slower).", IDC_LABEL_YOUTUBE_API_NOTE, 17, 80, 270, 10
    AUTOCHECKBOX    "Clear cache when MediaAccess closes", IDC_YT_CLEAR_ON_EXIT, 17, 105, 230, 10
    PUSHBUTTON      "Clear cache now...", IDC_YT_CLEAR_NOW, 17, 122, 100, 14
    LTEXT           "Limit cache size (MB, 0 = unlimited):", IDC_LABEL_YT_LIMIT, 17, 145, 145, 10
    EDITTEXT        IDC_YT_CACHE_LIMIT, 165, 143, 50, 14, ES_AUTOHSCROLL | ES_NUMBER

    // SoundTouch tab controls (shown when tab 9 selected)
    LTEXT           "SoundTouch settings (changes apply on next file load):", IDC_LABEL_SOUNDTOUCH_DESCRIPTION, 17, 30, 220, 10
    AUTOCHECKBOX    "&Anti-alias filter", IDC_ST_AA_FILTER, 17, 45, 100, 10
    LTEXT           "AA filter &length:", IDC_LABEL_SOUNDTOUCH_AA_LENGTH, 110, 47, 90, 10
    COMBOBOX        IDC_ST_AA_LENGTH, 205, 45, 60, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "&Quick algorithm (lower quality, less CPU)", IDC_ST_QUICK_ALGO, 17, 80, 210, 10
    AUTOCHECKBOX    "&Prevent click (reduces artifacts)", IDC_ST_PREVENT_CLICK, 17, 95, 170, 10
    LTEXT           "&Interpolation:", IDC_LABEL_SOUNDTOUCH_INTERPOLATION, 17, 115, 65, 10
    COMBOBOX        IDC_ST_ALGORITHM, 85, 113, 80, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Sequence (ms):", IDC_LABEL_SOUNDTOUCH_SEQUENCE, 17, 135, 55, 10
    EDITTEXT        IDC_ST_SEQUENCE, 75, 133, 35, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "See&k window:", IDC_LABEL_SOUNDTOUCH_SEEKWINDOW, 120, 135, 50, 10
    EDITTEXT        IDC_ST_SEEKWINDOW, 175, 133, 35, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "&Overlap:", IDC_LABEL_SOUNDTOUCH_OVERLAP, 220, 135, 40, 10
    EDITTEXT        IDC_ST_OVERLAP, 262, 133, 25, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "(0 = automatic for Sequence/Seek window)", IDC_LABEL_SOUNDTOUCH_AUTO_NOTE, 17, 152, 200, 10

    // Speedy tab controls (shown when tab 10 selected)
    LTEXT           "Google Speedy algorithm settings:", IDC_LABEL_SPEEDY_DESCRIPTION, 17, 30, 200, 10
    LTEXT           "Speedy uses nonlinear speedup optimized for speech.", IDC_LABEL_SPEEDY_INFO1, 17, 45, 290, 10
    LTEXT           "It compresses vowels more than consonants for clarity.", IDC_LABEL_SPEEDY_INFO2, 17, 57, 290, 10
    AUTOCHECKBOX    "&Enable nonlinear speedup (recommended for speech)", IDC_SPEEDY_NONLINEAR, 17, 78, 270, 10

    // Signalsmith tab controls (shown when tab 11 selected)
    LTEXT           "Signalsmith Stretch settings (changes apply on next file load):", IDC_LABEL_SIGNALSMITH_DESCRIPTION, 17, 30, 280, 10
    LTEXT           "&Quality preset:", IDC_LABEL_SIGNALSMITH_QUALITY, 17, 50, 80, 10
    COMBOBOX        IDC_SS_PRESET, 100, 48, 120, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "&Tonality limit (Hz, 0 = auto):", IDC_LABEL_SIGNALSMITH_TONALITY, 17, 72, 140, 10
    EDITTEXT        IDC_SS_TONALITY, 160, 70, 50, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Higher tonality limits preserve more harmonics during pitch shift.", IDC_LABEL_SIGNALSMITH_HARMONICS, 17, 90, 295, 10
    LTEXT           "Use 0 for automatic, or 4000-8000 for speech, 8000-16000 for music.", IDC_LABEL_SIGNALSMITH_VALUES, 17, 102, 300, 10

    // MIDI tab controls (shown when tab 12 selected)
    LTEXT           "MIDI playback settings (BASSMIDI):", IDC_LABEL_MIDI_DESCRIPTION, 17, 30, 150, 10
    LTEXT           "&SoundFont (.sf2/.sf3) — leave empty to use bundled FluidR3_GM:", IDC_LABEL_MIDI_SOUNDFONT, 17, 48, 280, 10
    EDITTEXT        IDC_MIDI_SOUNDFONT, 17, 60, 200, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "&Browse...", IDC_MIDI_SF_BROWSE, 222, 60, 50, 14
    LTEXT           "", IDC_LABEL_MIDI_SF_BUNDLED, 17, 76, 280, 10
    LTEXT           "Ma&x voices (polyphony):", IDC_LABEL_MIDI_VOICES, 17, 92, 125, 10
    EDITTEXT        IDC_MIDI_VOICES, 145, 90, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "(1-1000, default 128)", IDC_LABEL_MIDI_VOICES_RANGE, 190, 92, 105, 10
    AUTOCHECKBOX    "Use s&inc interpolation (higher quality, more CPU)", IDC_MIDI_SINC, 17, 110, 260, 10

    // Books tab controls (shown when tab 12 selected) — v1.49+1.50
    LTEXT           "Library folders (scanned for DAISY and EPUB books):", IDC_LABEL_BOOK_FOLDERS, 17, 30, 290, 10
    LISTBOX         IDC_BOOK_FOLDERS_LIST, 17, 44, 305, 80, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP | WS_BORDER
    PUSHBUTTON      "&Add folder...",     IDC_BOOK_FOLDER_ADD,    17, 128, 80, 14
    PUSHBUTTON      "&Remove folder",     IDC_BOOK_FOLDER_REMOVE, 100, 128, 80, 14
    PUSHBUTTON      "Re&scan now",        IDC_BOOK_RESCAN,        185, 128, 80, 14
    // Phase 2: TTS voice + text window theme + hide checkbox
    LTEXT           "&Text-to-speech voice (for text-only books):", IDC_LABEL_BOOK_TTS_VOICE, 17, 150, 290, 10
    COMBOBOX        IDC_BOOK_TTS_VOICE, 17, 162, 305, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Text &window theme:", IDC_LABEL_BOOK_TEXT_THEME, 17, 184, 95, 10
    COMBOBOX        IDC_BOOK_TEXT_THEME, 115, 182, 150, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Al&ways hide text window (audio-only experience)",
                    IDC_BOOK_HIDE_TEXT_WINDOW, 17, 204, 305, 10

    DEFPUSHBUTTON   "OK", IDOK, 229, 240, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 283, 240, 50, 14
END

// IDD_HOTKEY (legacy add/edit global-hotkey dialog) removed in v1.41 —
// global hotkeys are now managed from Tools → Actions, Global category.

IDD_URL DIALOGEX 0, 0, 300, 70
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Open URL"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Enter stream &URL (http/https):", -1, 7, 10, 150, 10
    EDITTEXT        IDC_URL_EDIT, 7, 24, 286, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 189, 48, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 243, 48, 50, 14
END

IDD_JUMPTOTIME DIALOGEX 0, 0, 200, 70
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Jump to Time"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Enter &time (mm:ss or hh:mm:ss):", -1, 7, 10, 150, 10
    EDITTEXT        IDC_JUMPTIME_EDIT, 7, 24, 186, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 89, 48, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 143, 48, 50, 14
END

IDD_PRESET_NAME DIALOGEX 0, 0, 220, 70
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Save Effect Preset"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Preset &name:", -1, 7, 10, 150, 10
    EDITTEXT        IDC_PRESET_NAME, 7, 24, 206, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 105, 48, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 160, 48, 50, 14
END

IDD_YOUTUBE DIALOGEX 0, 0, 350, 280
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "YouTube"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "&Search or paste URL:", -1, 7, 10, 100, 10
    EDITTEXT        IDC_YT_SEARCH, 7, 22, 336, 14, ES_AUTOHSCROLL
    LTEXT           "&Results:", -1, 7, 42, 50, 10
    LISTBOX         IDC_YT_RESULTS, 7, 54, 336, 200, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP
