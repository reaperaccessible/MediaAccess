// =========================================================================
// Actions / Keymap window — REAPER-style customizable shortcuts (Tools→Actions, F4)
// =========================================================================
IDD_ACTIONS DIALOGEX 0, 0, 480, 320
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Actions"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "Section:", IDC_LABEL_ACTIONS_CATEGORY, 10, 10, 50, 10
    COMBOBOX        IDC_ACTIONS_CATEGORY, 65, 8, 110, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Filter:", IDC_LABEL_ACTIONS_SEARCH, 190, 10, 30, 10
    EDITTEXT        IDC_ACTIONS_SEARCH, 220, 8, 160, 12, ES_AUTOHSCROLL
    PUSHBUTTON      "Find &shortcut...", IDC_ACTIONS_FIND_SHORTCUT, 385, 7, 85, 14

    LTEXT           "Actions:", IDC_LABEL_ACTIONS_LIST, 10, 28, 60, 10
    LISTBOX         IDC_ACTIONS_LIST, 10, 40, 290, 220, LBS_NOTIFY | LBS_USETABSTOPS | WS_VSCROLL | WS_TABSTOP | WS_BORDER

    LTEXT           "Shortcuts for selected action:", IDC_LABEL_ACTIONS_SHORTCUTS, 310, 28, 160, 10
    LISTBOX         IDC_ACTIONS_SHORTCUTS, 310, 40, 160, 110, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP | WS_BORDER

    PUSHBUTTON      "&Add...",    IDC_ACTIONS_ADD,    310, 158, 50, 14
    PUSHBUTTON      "&Edit...",   IDC_ACTIONS_EDIT,   365, 158, 50, 14
    PUSHBUTTON      "&Delete",    IDC_ACTIONS_DELETE, 420, 158, 50, 14

    LTEXT           "Current keymap:", IDC_LABEL_ACTIONS_KEYMAP, 10, 272, 70, 10
    LTEXT           "USA",        IDC_ACTIONS_KEYMAP_NAME, 82, 272, 150, 10

    PUSHBUTTON      "&Load...",         IDC_ACTIONS_LOAD,    10, 288, 65, 14
    PUSHBUTTON      "&Save as...",      IDC_ACTIONS_SAVE_AS, 80, 288, 65, 14
    PUSHBUTTON      "&Reset to defaults", IDC_ACTIONS_RESET, 150, 288, 100, 14

    DEFPUSHBUTTON   "Close", IDOK, 420, 300, 50, 14
END

